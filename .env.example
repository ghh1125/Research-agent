# Research Agent runtime configuration
# 说明：
# - 至少需要 1 个 LLM Provider API Key 和 1 个 Search Provider API Key。
# - 推荐最小配置：DashScope + Tavily。
# - 复制为 `.env` 后填写真实 key：cp .env.example .env
# - 不要把 `.env` 提交到 Git。

# =========================
# 1. LLM 路由（必填：至少配置一个 LLM Provider）
# =========================

# 必填。可选值：auto / dashscope / openai / openrouter / deepseek。
# 推荐先固定 dashscope，避免误走没有配置 key 的 Provider。
LLM_PROVIDER=dashscope

# 可选。备用 Provider 顺序，逗号分隔，例如：openai,openrouter,deepseek。
# 没有备用 key 时建议留空。
LLM_FALLBACK_PROVIDERS=

# 必填。单次 LLM 请求超时秒数；真实投研建议 120-180。
# CLI 可用 --llm-timeout 临时覆盖。
LLM_TIMEOUT_SECONDS=120

# =========================
# 2. DashScope（推荐必填）
# =========================

# 必填。阿里云百炼/DashScope API Key。
DASHSCOPE_API_KEY=

# 必填。DashScope OpenAI-compatible endpoint，一般不用改。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选。DashScope 默认模型；当 quick/deep 没单独设置时才用它。
DASHSCOPE_MODEL=deepseek-v4-flash

# 推荐必填。快模型：任务解析、研究计划、证据抽取。
DASHSCOPE_QUICK_MODEL=deepseek-v4-flash

# 推荐必填。强模型：专项分析、多空辩论、研究经理、估值、风控、组合经理。
# 如遇 DashScope FreeTierOnly/额度限制，需要在控制台关闭仅免费额度，或换成账号已开通模型。
DASHSCOPE_DEEP_MODEL=deepseek-v4-pro

# =========================
# 3. OpenAI（可选备用）
# =========================

# 可选。只有 LLM_PROVIDER=openai 或 fallback 包含 openai 时才需要。
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1
OPENAI_QUICK_MODEL=gpt-4.1-mini
OPENAI_DEEP_MODEL=gpt-4.1

# =========================
# 4. OpenRouter（可选备用）
# =========================

# 可选。只有 LLM_PROVIDER=openrouter 或 fallback 包含 openrouter 时才需要。
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1

# =========================
# 5. DeepSeek 官方 API（可选备用）
# =========================

# 可选。只有 LLM_PROVIDER=deepseek 或 fallback 包含 deepseek 时才需要。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# =========================
# 6. Search Provider（必填：至少配置一个）
# =========================

# 推荐必填。Tavily 搜索 API Key；当前项目会优先用 Tavily。
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com/search

# 可选备用。Serper Google Search API。
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev/search

# 可选备用。Google Custom Search；两个都要填才生效。
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_SEARCH_BASE_URL=https://www.googleapis.com/customsearch/v1

# =========================
# 7. 官方文件数据源（推荐填写）
# =========================

# 推荐必填。SEC 官方接口要求 User-Agent 里带可联系邮箱。
# 做美股 filings/companyfacts 时会用；A 股问题不一定用到。
SEC_USER_AGENT_EMAIL=research-agent@example.com
